<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Acceso al Sistema</title>
    <style>
        /* Reutilizamos variables básicas para mantenerlo independiente */
        body { font-family: system-ui, sans-serif; background: #f9fafb; margin: 0; display: flex; align-items: center; justify-content: center; height: 100vh; }
        .form-box { background: white; padding: 2.5rem; border-radius: 0.5rem; border: 1px solid #e5e7eb; width: 100%; max-width: 360px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
        h2 { margin-top: 0; color: #111827; }
        input { width: 100%; padding: 0.6rem; margin: 0.5rem 0 1.2rem 0; border: 1px solid #e5e7eb; border-radius: 0.375rem; box-sizing: border-box; }
        button { background: #2563eb; color: white; border: none; padding: 0.7rem; border-radius: 0.375rem; cursor: pointer; font-weight: 500; width: 100%; font-size: 1rem; }
        button:hover { background: #1d4ed8; }
        .toggle-actions { margin-top: 1.5rem; text-align: center; font-size: 0.9rem; color: #4b5563; }
        .toggle-actions span { color: #2563eb; cursor: pointer; font-weight: 500; }
        .btn-back { display: block; text-align: center; margin-top: 1rem; text-decoration: none; color: #9ca3af; font-size: 0.85rem; }
    </style>
</head>
<body>

<div class="form-box">
    <h2 id="form-title">Iniciar Sesión</h2>
    
    <form id="auth-form" action="validate" method="POST">
        <label for="usuario">Usuario / Email</label>
        <input type="text" name="usuario" id="usuario" required>
        
        <label for="password">Contraseña</label>
        <input type="password" name="password" id="password" required>
        
        <button type="submit" id="form-btn">Ingresar</button>
    </form>

    <div class="toggle-actions">
        <p id="toggle-text">¿No tienes cuenta? <span id="switch-btn">Regístrate</span></p>
    </div>
    
    <a href="./" class="btn-back">⬅️ Volver al inicio</a>
    
</div>

<script>
    const switchBtn = document.getElementById('switch-btn');
    const formTitle = document.getElementById('form-title');
    const authForm = document.getElementById('auth-form');
    const formBtn = document.getElementById('form-btn');
    const toggleText = document.getElementById('toggle-text');

    let isLogin = true;

    // Escuchamos el clic en todo el contenedor de texto para que no se rompa al redibujar
    toggleText.addEventListener('click', function(e) {
        // Validamos que el clic haya sido específicamente en el enlace (el <span>)
        if (e.target && e.target.id === 'switch-btn') {
            if (isLogin) {
                formTitle.textContent = "Crear Cuenta";
                authForm.action = "register";
                formBtn.textContent = "Registrarse";
                toggleText.innerHTML = '¿Ya tienes cuenta? <span id="switch-btn">Inicia sesión</span>';
                isLogin = false;
            } else {
                formTitle.textContent = "Iniciar Sesión";
                authForm.action = "validate";
                formBtn.textContent = "Ingresar";
                toggleText.innerHTML = '¿No tienes cuenta? <span id="switch-btn">Regístrate</span>';
                isLogin = true;
            }
        }
    });
</script>

</body>
</html>